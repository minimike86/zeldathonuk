# Django
# DJANGO_SECRET_KEY only needs to be set in production. In dev (DEBUG=1) a
# per-process random key is generated automatically.
# DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — when running under docker compose this is set automatically
# from the postgres service. Override only if you're running standalone.
# DATABASE_URL=postgres://zeldathon:zeldathon@localhost:5432/zeldathon

# CORS — comma-separated origins allowed to call this API
# Add any fixed origins here. In DEBUG, common LAN Vite URLs such as
# http://192.168.x.x:5173 are also allowed by regex from settings.py.
# In production the public site is a separate origin, so add it:
#   CORS_ALLOWED_ORIGINS=https://www.zeldathon.co.uk,https://zeldathon.co.uk
# (Extra origins can also be added live in the Django admin → Auth & access
# settings, without a redeploy.)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional extra regexes if you need custom dev hosts.
# CORS_ALLOWED_ORIGIN_REGEXES=
# Enables Chrome's private-network preflight response header.
CORS_ALLOW_PRIVATE_NETWORK=1
# Origins trusted for cross-origin admin form posts over the tunnel. Defaults to
# https://api.zeldathon.co.uk,https://www.zeldathon.co.uk in settings.py.
# CSRF_TRUSTED_ORIGINS=https://api.zeldathon.co.uk,https://www.zeldathon.co.uk

# Clerk authentication — Clerk owns sign-in; api.models.Profile owns the role
# (viewer/operator). The frontend sends Clerk session JWTs which the API
# verifies against each issuer's JWKS (<issuer>/.well-known/jwks.json). One API
# serves both localhost (dev Clerk instance) and the public site (prod
# instance), so trust BOTH issuers. These can also be set live in the Django
# admin → Auth & access settings (admin values win; blanks fall back to env).
#  - CLERK_ISSUERS: comma-separated trusted Frontend API URLs. Dev instances look
#    like https://your-app.clerk.accounts.dev; prod like https://clerk.zeldathon.co.uk
#  - CLERK_AUTHORIZED_PARTIES: allowed `azp` (every frontend origin).
CLERK_ISSUERS=https://your-app.clerk.accounts.dev,https://clerk.zeldathon.co.uk
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,https://www.zeldathon.co.uk
# Optional — reserved for the Clerk Management API (never sent to the frontend).
# CLERK_SECRET_KEY=

# Stream Deck / macro pad shared secret sent as the X-Hotkey-Secret header to
# /api/timer-hotkey/ (that endpoint is machine-driven, so it's gated by this
# secret instead of a Clerk login). In DEBUG it may be left blank. Generate one
# with `openssl rand -hex 32`. Also settable in the Django admin.
TIMER_HOTKEY_SECRET=

# Third-party API credentials (proxied from the frontend) — fill in when
# the corresponding proxy endpoints get implemented.
TILTIFY_ACCESS_TOKEN=

# JustGiving App ID (used in the API URL path). The page short name(s) are
# configured per-event as Donation Pages in /control/events.
JUSTGIVING_API_KEY=
# JustGiving API target: 'production' (api.justgiving.com) or 'staging'
# (api.staging.justgiving.com).
JUSTGIVING_ENV=production

# App-credentials secret — used by the "Refresh IGDB metadata" admin action to
# mint a token against IGDB, and to refresh the user OAuth token below.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# User OAuth — bootstrap only. Get both via `twitch token -u -s channel:manage:schedule`.
# After the first request the values get copied into the TwitchOAuthToken row and the
# server self-refreshes against id.twitch.tv/oauth2/token using the refresh_token.
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=
# Optional. The broadcaster's numeric Twitch user id is auto-resolved from the
# user token above, so leave this blank in normal use. Set it only to force a
# specific channel id.
TWITCH_BROADCASTER_ID=
# EventSub webhook (follows/subs/cheers/raids/charity → omnibar). Needed only to
# register subscriptions via `manage.py twitch_eventsub`:
#  - SECRET: any 10-100 char string Twitch signs deliveries with (also verified
#    on intake). Generate one, e.g. `openssl rand -hex 32`.
#  - CALLBACK_URL: the PUBLIC https URL of the eventsub endpoint, e.g.
#    https://your-tunnel-domain/api/twitch/eventsub/
TWITCH_EVENTSUB_SECRET=
TWITCH_EVENTSUB_CALLBACK_URL=
